# =============================================================================
# CV Builder — Frontend Environment Variables
# -----------------------------------------------------------------------------
# NEVER commit .env.local to GitHub. This file (.env.example) is safe to commit
# because it contains only placeholder values, not real secrets.
#
# LOCAL SETUP:
#   Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# PRODUCTION:
#   Set these variables directly in the Vercel dashboard.
#   Do not create a .env.local file for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# Local:      http://localhost:3001/api
# Production: https://your-backend.koyeb.app/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_STRIPE=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
